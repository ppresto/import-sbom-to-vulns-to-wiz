# --- Wiz API credentials ---
WIZ_CLIENT_ID=your-service-account-client-id
WIZ_CLIENT_SECRET=your-service-account-client-secret
WIZ_TOKEN_URL=https://auth.app.wiz.io/oauth/token

# --- Wiz enrichment integration ---
# Built-in enrichment integration ID (works with any SA that has create:external_data_ingestion)
WIZ_INTEGRATION_ID=55c176cc-d155-43a2-98ed-aa56873a1ca1

# --- Target repository branch in Wiz ---
# Find asset ID: Wiz UI → Inventory → Repositories → click your repo → copy ID from URL
REPO_ASSET_ID=your-wiz-repo-branch-asset-id
REPO_NAME=owner/repo-name
REPO_BRANCH=main
REPO_URL=https://github.com/owner/repo-name
VCS_TYPE=GitHub

# --- Pipeline config ---
# Consistent across runs so Wiz replaces (not duplicates) findings
DATASOURCE_ID=sbom-import-owner-repo-name-main
